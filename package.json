{
  "name": "huddle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "tsx --test tests/**/*.test.ts",
    "db:generate": "npm --workspace @huddle/server run db:generate",
    "db:migrate:deploy": "npm --workspace @huddle/server run db:migrate:deploy"
  },
  "devDependencies": {
    "tsx": "4.23.0",
    "turbo": "2.10.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
