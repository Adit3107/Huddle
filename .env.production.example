NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/huddle?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/huddle?sslmode=require

# Redis / realtime
REDIS_URL=rediss://default:PASSWORD@HOST:6379
CORS_ORIGIN=https://your-huddle-web.vercel.app
SOCKET_CORS_ORIGIN=https://your-huddle-web.vercel.app
BULLMQ_QUEUE_PREFIX=huddle
REALTIME_WORKER_CONCURRENCY=5
TYPING_TIMEOUT_MS=3000
HEARTBEAT_TTL_SECONDS=45

# Web URLs
NEXT_PUBLIC_APP_URL=https://your-huddle-web.vercel.app
NEXT_PUBLIC_BACKEND_URL=https://your-huddle-api.railway.app
NEXTAUTH_URL=https://your-huddle-web.vercel.app

# Auth.js / Google OAuth
AUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_SECRET=replace-with-same-value-as-auth-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
JWT_SECRET=replace-with-a-different-strong-random-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
